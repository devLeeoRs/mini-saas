PORT=3001
NODE_ENV=production

# ERP DB (produtos/estoque)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# APP DB (autenticacao/roles) - Postgres separado
# Recomendada: use URL
APP_DATABASE_URL=
# Opcional (caso o Postgres exija SSL)
APP_DB_SSL=0
# Alternativa: use host/port/name/user/pass
APP_DB_HOST=
APP_DB_PORT=5432
APP_DB_NAME=
APP_DB_USER=
APP_DB_PASSWORD=

# Auth
AUTH_JWT_SECRET=change-me
AUTH_JWT_EXPIRES=7d

